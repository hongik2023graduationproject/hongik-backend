# Server
PORT=8080
ENV=production

# Interpreter
INTERPRETER_PATH=/app/HongIk

# JWT
JWT_SECRET=change-me-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=https://hongik.tolelom.xyz,https://hongik.docs.tolelom.xyz

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@postgres:5432/hongik?sslmode=disable

# Execution limits
MAX_CONCURRENT_EXEC=5
MAX_OUTPUT_BYTES=1048576
